# ── DATABASE ────────────────────────────────────────────
DATABASE_URL="postgresql://laplasse:laplasse_dev@localhost:5433/laplasse_db"

# ── AUTH ─────────────────────────────────────────────────
JWT_SECRET="change-me-in-production-min-32-chars"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="30d"

# ── REDIS ────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── MEILISEARCH ──────────────────────────────────────────
MEILI_HOST="http://localhost:7700"
MEILI_MASTER_KEY="laplasse_meili_dev_key"

# ── APP ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
APP_NAME=LaPlasse
APP_URL=http://localhost:3000

# ── EMAIL (dev: Mailtrap ou MailHog) ─────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM="noreply@laplasse.local"

# ── FRONTEND ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_APP_NAME=LaPlasse
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_CITY=Abidjan
NEXT_PUBLIC_DEFAULT_DISTRICT=Cocody
