# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/laplasse_db?schema=public

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_IN_PRODUCTION_MINIMUM_32_CHARS
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Meilisearch ───────────────────────────────────────────────────────────────
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=CHANGE_THIS_IN_PRODUCTION

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
APP_NAME=LaPlasse
APP_URL=https://laplasse.ci

# ── Monitoring (remplir en production) ───────────────────────────────────────
SENTRY_DSN=
