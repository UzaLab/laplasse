# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/laplasse_db?schema=public

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_IN_PRODUCTION_MINIMUM_32_CHARS
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Meilisearch ───────────────────────────────────────────────────────────────
# Obligatoire en production (NODE_ENV=production) — pas de fallback Prisma.
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=CHANGE_THIS_IN_PRODUCTION
# MEILI_REQUIRED=true  # force Meilisearch même en dev/staging

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
APP_NAME=LaPlasse
APP_URL=https://laplasse.ci

# ── Storage (Hetzner Object Storage — S3-compatible) ─────────────────────────
# Laisser vide pour utiliser le disque local (dev).
# En WSL / dev local, forcer le stockage disque même si S3 est configuré :
STORAGE_FORCE_LOCAL=true
# Doc complète : Docs/STORAGE_HETZNER.md
STORAGE_PROVIDER=s3
R2_ENDPOINT=https://fsn1.your-objectstorage.com
R2_REGION=fsn1
R2_BUCKET_NAME=laplasse-preprod
R2_PUBLIC_URL=https://media-preprod.laplasse.tech
# Coolify : utiliser S3_* (pas R2_ACCESS_KEY_ID — bug Coolify Build/Runtime)
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Legacy Cloudflare R2 (alternative — ne pas mélanger avec Hetzner)
# R2_ACCOUNT_ID=
# R2_BUCKET=laplasse-media

API_PUBLIC_URL=https://api.laplasse.ci

# ── Push Web (VAPID) — générer avec: npx web-push generate-vapid-keys ─────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@laplasse.ci
# FCM_SERVER_KEY=  # optionnel — apps natives Android/iOS
SENTRY_DSN=
