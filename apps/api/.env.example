# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/laplasse_db?schema=public

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_IN_PRODUCTION_MINIMUM_32_CHARS
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Meilisearch ───────────────────────────────────────────────────────────────
# Obligatoire en production (NODE_ENV=production) — pas de fallback Prisma.
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=CHANGE_THIS_IN_PRODUCTION
# MEILI_REQUIRED=true  # force Meilisearch même en dev/staging

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
APP_NAME=LaPlasse
APP_URL=https://laplasse.ci

# ── Storage (Cloudflare R2) ───────────────────────────────────────────────────
# Laisser vide pour utiliser le disque local (dev)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=laplasse-media
R2_PUBLIC_URL=https://media.laplasse.ci
API_PUBLIC_URL=https://api.laplasse.ci

# ── Push Web (VAPID) — générer avec: npx web-push generate-vapid-keys ─────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@laplasse.ci
# FCM_SERVER_KEY=  # optionnel — apps natives Android/iOS
SENTRY_DSN=
