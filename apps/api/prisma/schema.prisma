// LaPlasse — Prisma Schema v1.0
// Datasource: PostgreSQL local (port 5433)

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ─────────────────────────────────────────────────────────────────────

enum Role {
  USER
  MERCHANT
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum SubscriptionPlan {
  FREE
  STARTER
  GROWTH
  PREMIUM
}

enum MediaType {
  IMAGE
  VIDEO
  MENU
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

enum VerificationType {
  PHONE
  DOCUMENT
  BUSINESS_ID
  SOCIAL
}

enum ComplaintStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  TRIAL
}

enum InteractionType {
  VIEW
  CALL_CLICK
  WHATSAPP_CLICK
  DIRECTION_CLICK
  WEBSITE_CLICK
  SAVE
  REVIEW
  SHARE
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum OrganizationType {
  CHAIN
  GROUP
  MULTI_SITE
}

// ─── USERS ─────────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  phone         String?  @unique
  full_name     String?
  avatar        String?
  role          Role     @default(USER)
  city          String?
  country       String?  @default("CI")
  password_hash String?
  is_active     Boolean  @default(true)
  is_verified   Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  reviews          Review[]
  favorites        Favorite[]
  product_favorites ProductFavorite[]
  product_reviews   ProductReview[]
  searches         SearchHistory[]
  interactions     MerchantInteraction[]
  merchants        Merchant[]
  notifications    Notification[]
  analytics_events AnalyticsEvent[]
  loyalty_account  LoyaltyAccount?
  referral_code    ReferralCode?
  referral_invite  Referral?           @relation("ReferralInvitee")
  organization     MerchantOrganization?
  bookings         Booking[]
  payments         PaymentTransaction[]
  device_tokens    DeviceToken[]
  audit_logs       AuditLog[]
  cart             Cart?
  orders           Order[]
  order_returns    OrderReturn[]
  shops            Shop[]
  promotion_redemptions PromotionRedemption[]
  addresses        UserAddress[]
  product_views    ProductView[]

  @@index([email])
  @@index([phone])
}

model AuthToken {
  id         String   @id @default(cuid())
  user_id    String
  token      String   @unique
  type       String   // "refresh" | "otp" | "email_verify"
  expires_at DateTime
  created_at DateTime @default(now())

  @@index([user_id])
  @@index([token])
}

// ─── MERCHANT CORE ─────────────────────────────────────────────────────────────

model Merchant {
  id                  String             @id @default(cuid())
  business_name       String
  slug                String             @unique
  description         String?
  category_id         String
  owner_id            String
  logo                String?
  cover_image         String?
  phone               String?
  whatsapp            String?
  email               String?
  website             String?
  verification_status VerificationStatus @default(UNVERIFIED)
  trust_score         Int                @default(0)
  subscription_plan   SubscriptionPlan   @default(FREE)
  organization_id     String?
  is_active           Boolean            @default(true)
  is_sponsored        Boolean            @default(false)
  food_prep_minutes   Int                @default(25)
  created_at          DateTime           @default(now())
  updated_at          DateTime           @updatedAt

  owner         User                  @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  organization  MerchantOrganization? @relation(fields: [organization_id], references: [id], onDelete: SetNull)
  category      Category              @relation(fields: [category_id], references: [id])
  location      MerchantLocation?
  media         MerchantMedia[]
  reviews       Review[]
  favorites     Favorite[]
  interactions  MerchantInteraction[]
  verifications MerchantVerification[]
  complaints    Complaint[]
  subscription  Subscription?
  hours         BusinessHour[]
  tags          MerchantTag[]
  promotions    Promotion[]
  bookings         Booking[]
  payments         PaymentTransaction[]
  booking_settings MerchantBookingSettings?
  services         MerchantService[]
  staff            MerchantStaff[]
  availability_blocks MerchantAvailabilityBlock[]
  ad_campaigns     AdCampaign[]
  shop             Shop?
  orders           Order[]
  menu_sections    MenuSection[]
  menu_items       MenuItem[]

  @@index([slug])
  @@index([category_id])
  @@index([verification_status])
  @@index([trust_score])
  @@index([is_active])
  @@index([organization_id])
}

model MerchantOrganization {
  id         String           @id @default(cuid())
  name       String
  type       OrganizationType
  owner_id   String           @unique
  logo       String?
  created_at DateTime         @default(now())
  updated_at DateTime         @updatedAt

  owner     User       @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  merchants Merchant[]

  @@index([owner_id])
}

model MerchantLocation {
  id              String  @id @default(cuid())
  merchant_id     String  @unique
  country         String  @default("CI")
  city            String
  district        String?
  address         String?
  latitude        Float?
  longitude       Float?
  google_place_id String?

  merchant Merchant @relation(fields: [merchant_id], references: [id], onDelete: Cascade)

  @@index([city])
  @@index([district])
  @@index([latitude, longitude])
}

// ─── GÉOGRAPHIE (référentiel pays › ville › commune) ───────────────────────────

model GeoCity {
  id         String   @id @default(cuid())
  country    String   // ISO 3166-1 alpha-2 : CI, BF
  name       String
  slug       String
  is_default Boolean  @default(false)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  communes GeoCommune[]
  zone_rules ShopDeliveryZoneRule[]
  user_addresses UserAddress[]

  @@unique([country, slug])
  @@index([country, is_active])
}

model GeoCommune {
  id         String   @id @default(cuid())
  city_id    String
  name       String
  slug       String
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  city GeoCity @relation(fields: [city_id], references: [id], onDelete: Cascade)
  zone_communes ShopDeliveryZoneCommune[]
  user_addresses UserAddress[]

  @@unique([city_id, slug])
  @@index([city_id, is_active])
}

model UserAddress {
  id              String   @id @default(cuid())
  user_id         String
  label           String?
  city_id         String
  commune_id      String
  district        String
  address_detail  String?
  is_default      Boolean  @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  user    User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  city    GeoCity    @relation(fields: [city_id], references: [id], onDelete: Restrict)
  commune GeoCommune @relation(fields: [commune_id], references: [id], onDelete: Restrict)

  @@index([user_id])
  @@index([user_id, is_default])
}

model BusinessHour {
  id          String  @id @default(cuid())
  merchant_id String
  day         Int     // 0=Lundi … 6=Dimanche
  open_time   String? // "08:00"
  close_time  String? // "22:00"
  is_closed   Boolean @default(false)

  merchant Merchant @relation(fields: [merchant_id], references: [id], onDelete: Cascade)

  @@unique([merchant_id, day])
  @@index([merchant_id])
}

// ─── CATEGORIES ────────────────────────────────────────────────────────────────

model Category {
  id         String     @id @default(cuid())
  name       String
  slug       String     @unique
  parent_id  String?
  icon       String?
  sort_order Int        @default(0)
  is_active  Boolean    @default(true)
  created_at DateTime   @default(now())

  parent    Category?  @relation("CategoryHierarchy", fields: [parent_id], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  merchants Merchant[]

  @@index([slug])
  @@index([parent_id])
}

// ─── MEDIA ─────────────────────────────────────────────────────────────────────

model MerchantMedia {
  id          String    @id @default(cuid())
  merchant_id String
  type        MediaType @default(IMAGE)
  url         String
  thumbnail   String?
  order       Int       @default(0)
  uploaded_by String
  created_at  DateTime  @default(now())

  merchant Merchant @relation(fields: [merchant_id], references: [id], onDelete: Cascade)

  @@index([merchant_id])
}

// ─── TAGS ──────────────────────────────────────────────────────────────────────

model Tag {
  id        String        @id @default(cuid())
  name      String        @unique
  merchants MerchantTag[]
}

model MerchantTag {
  merchant_id String
  tag_id      String

  merchant Merchant @relation(fields: [merchant_id], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([merchant_id, tag_id])
}

// ─── REVIEWS & TRUST ───────────────────────────────────────────────────────────

model Review {
  id          String       @id @default(cuid())
  merchant_id String
  user_id     String
  rating      Int          // 1–5
  title       String?
  content     String?
  media       Json?        // URLs images (array)
  status      ReviewStatus @default(PENDING)
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt

  merchant Merchant @relation(fields: [merchant_id], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([merchant_id])
  @@index([user_id])
  @@index([status])
}

model Favorite {
  id          String   @id @default(cuid())
  user_id     String
  merchant_id String
  created_at  DateTime @default(now())

  user     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  merchant Merchant @relation(fields: [merchant_id], references: [id], onDelete: Cascade)

  @@unique([user_id, merchant_id])
  @@index([user_id])
  @@index([merchant_id])
}

model ProductFavorite {
  id         String   @id @default(cuid())
  user_id    String
  product_id String
  created_at DateTime @default(now())

  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([user_id, product_id])
  @@index([user_id])
  @@index([product_id])
}

model ProductCategory {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  icon       String?
  parent_id  String?
  sort_order Int      @default(0)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  parent    ProductCategory?         @relation("ProductCategoryTree", fields: [parent_id], references: [id], onDelete: SetNull)
  children  ProductCategory[]        @relation("ProductCategoryTree")
  countries ProductCategoryCountry[]
  products  Product[]
  shops     ShopProductCategory[]
  promotions Promotion[]

  @@index([parent_id, sort_order])
  @@index([is_active])
}

model ProductCategoryCountry {
  category_id  String
  country_code String @db.Char(2)

  category ProductCategory @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@id([category_id, country_code])
  @@index([country_code])
}

model ShopProductCategory {
  shop_id     String
  category_id String
  created_at  DateTime @default(now())

  shop     Shop            @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  category ProductCategory @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@id([shop_id, category_id])
  @@index([category_id])
}

// ─── VERIFICATION & MODERATION ─────────────────────────────────────────────────

model MerchantVerification {
  id                String           @id @default(cuid())
  merchant_id       String
  verification_type VerificationType
  document_url      String?
  status            String           @default("pending")
  verified_by       String?
  notes             String?
  verified_at       DateTime?
  created_at        DateTime         @default(now())

  merchant Merchant @relation(fields: [merchant_id], references: [id], onDelete: Cascade)

  @@index([merchant_id])
  @@index([status])
}

model Complaint {
  id          String          @id @default(cuid())
  merchant_id String
  user_id     String
  reason      String
  description String?
  status      ComplaintStatus @default(OPEN)
  assigned_to String?
  created_at  DateTime        @default(now())
  resolved_at DateTime?

  merchant Merchant @relation(fields: [merchant_id], references: [id], onDelete: Cascade)

  @@index([merchant_id])
  @@index([status])
}

// ─── SUBSCRIPTION ──────────────────────────────────────────────────────────────

model Subscription {
  id            String             @id @default(cuid())
  merchant_id   String             @unique
  plan          SubscriptionPlan   @default(FREE)
  status        SubscriptionStatus @default(ACTIVE)
  billing_cycle String?            // "monthly" | "yearly"
  started_at    DateTime           @default(now())
  expires_at    DateTime?
  created_at    DateTime           @default(now())

  merchant Merchant @relation(fields: [merchant_id], references: [id], onDelete: Cascade)

  @@index([merchant_id])
  @@index([status])
}

// ─── ANALYTICS & BEHAVIOR ──────────────────────────────────────────────────────

model SearchHistory {
  id            String   @id @default(cuid())
  user_id       String?
  query         String
  filters       Json?
  city          String?
  latitude      Float?
  longitude     Float?
  results_count Int      @default(0)
  created_at    DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([query])
  @@index([city])
}

model MerchantInteraction {
  id          String          @id @default(cuid())
  user_id     String?
  merchant_id String
  event_type  InteractionType
  metadata    Json?
  created_at  DateTime        @default(now())

  user     User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)
  merchant Merchant @relation(fields: [merchant_id], references: [id], onDelete: Cascade)

  @@index([merchant_id])
  @@index([user_id])
  @@index([event_type])
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  user_id    String?
  event_name String
  properties Json?
  city       String?
  created_at DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([event_name])
  @@index([user_id])
  @@index([created_at])
}

// ─── NOTIFICATIONS ─────────────────────────────────────────────────────────────

model Notification {
  id         String             @id @default(cuid())
  user_id    String
  type       String             // "review_approved" | "merchant_verified" | "loyalty_level" | "referral_reward"
  channel    String             @default("in_app") // "in_app" | "email" | "push"
  title      String
  body       String
  data       Json?              // payload contextuel
  read       Boolean            @default(false)
  status     NotificationStatus @default(PENDING)
  sent_at    DateTime?
  created_at DateTime           @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([status])
  @@index([read])
  @@index([created_at])
}

// ─── LOYALTY ───────────────────────────────────────────────────────────────────

enum LoyaltyTier {
  EXPLORER
  LOCAL
  INSIDER
  AMBASSADOR
}

model LoyaltyAccount {
  id          String      @id @default(cuid())
  user_id     String      @unique
  points      Int         @default(0)
  tier        LoyaltyTier @default(EXPLORER)
  total_earned Int        @default(0)
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt

  user         User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  transactions LoyaltyTransaction[]

  @@index([user_id])
  @@index([tier])
}

model LoyaltyTransaction {
  id          String   @id @default(cuid())
  account_id  String
  points      Int      // positif = gain, négatif = dépense
  reason      String   // "review", "favorite", "share", "signup_merchant", "referral_invite"
  metadata    Json?
  created_at  DateTime @default(now())

  account LoyaltyAccount @relation(fields: [account_id], references: [id], onDelete: Cascade)

  @@index([account_id])
  @@index([created_at])
}

// ─── REFERRAL ──────────────────────────────────────────────────────────────────

model ReferralCode {
  id         String   @id @default(cuid())
  user_id    String   @unique
  code       String   @unique
  uses_count Int      @default(0)
  created_at DateTime @default(now())

  user    User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  invites Referral[]

  @@index([code])
}

model Referral {
  id              String   @id @default(cuid())
  referral_code_id String
  invited_user_id String   @unique
  rewarded        Boolean  @default(false)
  created_at      DateTime @default(now())

  code         ReferralCode @relation(fields: [referral_code_id], references: [id])
  invited_user User         @relation("ReferralInvitee", fields: [invited_user_id], references: [id], onDelete: Cascade)

  @@index([referral_code_id])
}

// ─── PROMOTIONS ────────────────────────────────────────────────────────────────

enum PromotionType {
  PERCENTAGE
  FIXED
  FREE_ITEM
  EARLY_ACCESS
  FREE_DELIVERY
}

model Promotion {
  id               String        @id @default(cuid())
  merchant_id      String
  shop_id          String?
  category_id      String?
  title            String
  description      String?
  type             PromotionType @default(PERCENTAGE)
  value            Float         // % ou montant FCFA
  code             String?
  min_order_amount Int?
  is_active        Boolean       @default(true)
  starts_at        DateTime
  ends_at          DateTime
  max_uses         Int?
  uses_count       Int           @default(0)
  created_at       DateTime      @default(now())

  merchant    Merchant              @relation(fields: [merchant_id], references: [id], onDelete: Cascade)
  shop        Shop?                 @relation(fields: [shop_id], references: [id], onDelete: SetNull)
  category    ProductCategory?      @relation(fields: [category_id], references: [id], onDelete: SetNull)
  orders      Order[]
  redemptions PromotionRedemption[]

  @@unique([merchant_id, code])
  @@index([merchant_id])
  @@index([shop_id])
  @@index([category_id])
  @@index([is_active])
  @@index([ends_at])
}

model ProductReview {
  id         String       @id @default(cuid())
  product_id String
  user_id    String
  order_id   String?
  rating     Int
  comment    String?
  status     ReviewStatus @default(PENDING)
  created_at DateTime     @default(now())

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([product_id, user_id])
  @@index([product_id])
  @@index([status])
}

model MenuSection {
  id          String   @id @default(cuid())
  merchant_id String
  shop_id     String?
  name        String
  sort_order  Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  merchant Merchant   @relation(fields: [merchant_id], references: [id], onDelete: Cascade)
  shop     Shop?      @relation(fields: [shop_id], references: [id], onDelete: SetNull)
  items    MenuItem[]

  @@index([merchant_id, sort_order])
  @@index([shop_id, sort_order])
}

model MenuItem {
  id           String   @id @default(cuid())
  merchant_id  String
  shop_id      String?
  section_id   String?
  name         String
  description  String?
  price        Int
  currency     String   @default("XOF")
  image_url    String?
  is_available Boolean  @default(true)
  prep_minutes Int?
  sort_order   Int      @default(0)
  created_at   DateTime @default(now())

  merchant        Merchant            @relation(fields: [merchant_id], references: [id], onDelete: Cascade)
  shop            Shop?               @relation(fields: [shop_id], references: [id], onDelete: SetNull)
  section         MenuSection?        @relation(fields: [section_id], references: [id], onDelete: SetNull)
  modifier_groups MenuModifierGroup[]
  cart_items      CartItem[]
  order_items     OrderItem[]

  @@index([merchant_id, sort_order])
  @@index([shop_id, sort_order])
  @@index([section_id])
}

model MenuModifierGroup {
  id           String   @id @default(cuid())
  menu_item_id String
  name         String
  min_select   Int      @default(0)
  max_select   Int      @default(1)
  sort_order   Int      @default(0)
  created_at   DateTime @default(now())

  menu_item MenuItem             @relation(fields: [menu_item_id], references: [id], onDelete: Cascade)
  options   MenuModifierOption[]

  @@index([menu_item_id, sort_order])
}

model MenuModifierOption {
  id           String  @id @default(cuid())
  group_id     String
  name         String
  price_delta  Int     @default(0)
  is_available Boolean @default(true)
  sort_order   Int     @default(0)

  group MenuModifierGroup @relation(fields: [group_id], references: [id], onDelete: Cascade)

  @@index([group_id, sort_order])
}

model PromotionRedemption {
  id           String   @id @default(cuid())
  promotion_id String
  order_id     String   @unique
  user_id      String
  amount_saved Int
  created_at   DateTime @default(now())

  promotion Promotion @relation(fields: [promotion_id], references: [id], onDelete: Cascade)
  order     Order     @relation(fields: [order_id], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([promotion_id])
  @@index([user_id])
}

// ─── PAYMENTS (simulateur V1) ──────────────────────────────────────────────────

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

enum PaymentProvider {
  SIMULATOR
}

enum PaymentPurpose {
  SUBSCRIPTION
  AD_CAMPAIGN
  ORDER
  BOOKING
}

model PaymentTransaction {
  id          String             @id @default(cuid())
  user_id     String
  merchant_id String?
  shop_id     String?
  purpose     PaymentPurpose     @default(SUBSCRIPTION)
  provider    PaymentProvider    @default(SIMULATOR)
  plan        SubscriptionPlan?
  order_id    String?            @unique
  booking_id  String?            @unique
  amount      Int
  currency    String             @default("XOF")
  status      PaymentStatus      @default(PENDING)
  reference   String             @unique
  metadata    Json?
  created_at  DateTime           @default(now())
  paid_at     DateTime?

  user     User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  merchant Merchant? @relation(fields: [merchant_id], references: [id], onDelete: SetNull)
  shop     Shop?     @relation(fields: [shop_id], references: [id], onDelete: SetNull)
  order    Order?    @relation(fields: [order_id], references: [id], onDelete: SetNull)
  booking  Booking?  @relation(fields: [booking_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([merchant_id])
  @@index([shop_id])
  @@index([status])
  @@index([reference])
}

// ─── BOOKINGS ──────────────────────────────────────────────────────────────────

enum BookingType {
  TABLE
  APPOINTMENT
  ROOM
  CONSULTATION
  VENUE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum ServiceKind {
  APPOINTMENT
  TABLE_MENU
  ROOM_TYPE
  CONSULTATION
}

model MerchantBookingSettings {
  merchant_id           String  @id
  max_capacity          Int     @default(20)
  slot_duration_min     Int     @default(60)
  buffer_min            Int     @default(15)
  booking_window_days   Int     @default(30)
  auto_confirm          Boolean @default(false)
  require_payment       Boolean @default(false)
  deposit_percent       Int     @default(100)
  cancellation_policy   String?
  no_show_policy        String?

  merchant Merchant @relation(fields: [merchant_id], references: [id], onDelete: Cascade)
}

model MerchantService {
  id            String      @id @default(cuid())
  merchant_id   String
  name          String
  service_kind  ServiceKind @default(APPOINTMENT)
  description   String?
  duration_min  Int         @default(60)
  price         Int?
  nightly_rate          Int?
  weekend_nightly_rate  Int?
  peak_nightly_rate     Int?
  peak_months           Json     @default("[]")
  min_stay_nights       Int      @default(1)
  capacity              Int?
  staff_id      String?
  is_active     Boolean     @default(true)
  image_urls    Json        @default("[]")
  bedrooms      Int?
  bathrooms     Int?
  beds          Int?
  property_type String?
  unit_type     String?
  amenities     Json        @default("[]")
  highlights    Json        @default("[]")
  created_at    DateTime    @default(now())

  merchant Merchant       @relation(fields: [merchant_id], references: [id], onDelete: Cascade)
  staff    MerchantStaff? @relation(fields: [staff_id], references: [id], onDelete: SetNull)
  bookings Booking[]
  blocks   MerchantAvailabilityBlock[]

  @@index([merchant_id])
  @@index([staff_id])
}

model MerchantStaff {
  id          String  @id @default(cuid())
  merchant_id String
  name        String
  role        String?
  is_active   Boolean @default(true)
  created_at  DateTime @default(now())

  merchant Merchant                    @relation(fields: [merchant_id], references: [id], onDelete: Cascade)
  bookings Booking[]
  services MerchantService[]
  blocks   MerchantAvailabilityBlock[]

  @@index([merchant_id])
}

model MerchantAvailabilityBlock {
  id          String   @id @default(cuid())
  merchant_id String
  starts_at   DateTime
  ends_at     DateTime
  all_day     Boolean  @default(false)
  staff_id    String?
  service_id  String?
  reason      String?
  created_at  DateTime @default(now())

  merchant Merchant         @relation(fields: [merchant_id], references: [id], onDelete: Cascade)
  staff    MerchantStaff?   @relation(fields: [staff_id], references: [id], onDelete: SetNull)
  service  MerchantService?   @relation(fields: [service_id], references: [id], onDelete: SetNull)

  @@index([merchant_id])
  @@index([starts_at, ends_at])
}

model Booking {
  id               String        @id @default(cuid())
  merchant_id      String
  user_id          String?
  booking_type     BookingType   @default(TABLE)
  guest_name       String
  guest_phone      String
  guest_email      String?
  booked_at        DateTime
  check_out_at     DateTime?
  party_size       Int           @default(1)
  service_id       String?
  staff_id         String?
  room_type        String?
  notes            String?
  metadata         Json?
  status           BookingStatus @default(PENDING)
  reminder_sent_at DateTime?
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt

  merchant Merchant         @relation(fields: [merchant_id], references: [id], onDelete: Cascade)
  user     User?            @relation(fields: [user_id], references: [id], onDelete: SetNull)
  service  MerchantService? @relation(fields: [service_id], references: [id], onDelete: SetNull)
  staff    MerchantStaff?   @relation(fields: [staff_id], references: [id], onDelete: SetNull)
  payment  PaymentTransaction?

  @@index([merchant_id])
  @@index([user_id])
  @@index([booked_at])
  @@index([status])
  @@index([booking_type])
}

// ─── ADS SELF-SERVICE ──────────────────────────────────────────────────────────

enum AdCampaignStatus {
  DRAFT
  PENDING_PAYMENT
  ACTIVE
  EXPIRED
  CANCELLED
}

enum AdPlacement {
  SEARCH
  FEATURED
  CATEGORY
  MARKETPLACE
}

model AdCampaign {
  id          String           @id @default(cuid())
  merchant_id String
  placement   AdPlacement      @default(SEARCH)
  status      AdCampaignStatus @default(DRAFT)
  amount      Int
  starts_at   DateTime
  ends_at     DateTime
  impressions Int              @default(0)
  clicks      Int              @default(0)
  payment_id  String?
  created_at  DateTime         @default(now())

  merchant Merchant @relation(fields: [merchant_id], references: [id], onDelete: Cascade)

  @@index([merchant_id])
  @@index([status])
  @@index([ends_at])
}

// ─── PLATFORM SETTINGS ─────────────────────────────────────────────────────────

model PlatformSetting {
  key        String   @id
  value      String
  updated_at DateTime @updatedAt
}

// ─── AUDIT & FRAUD ─────────────────────────────────────────────────────────────

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  PAYMENT
  MODERATION
}

model AuditLog {
  id          String      @id @default(cuid())
  user_id     String?
  action      AuditAction
  entity_type String
  entity_id   String?
  payload     Json?
  ip          String?
  created_at  DateTime    @default(now())

  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([entity_type, entity_id])
  @@index([created_at])
}

model FraudSignal {
  id          String   @id @default(cuid())
  signal_type String
  severity    String   @default("medium")
  entity_type String
  entity_id   String?
  details     Json?
  resolved    Boolean  @default(false)
  created_at  DateTime @default(now())

  @@index([resolved])
  @@index([created_at])
}

model DeviceToken {
  id         String   @id @default(cuid())
  user_id    String
  token      String   @unique
  platform   String   @default("web")
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

// ─── MARKETPLACE V1.6 — Boutique (Shop) modulaire ─────────────────────────────

enum DeliveryVehicle {
  MOTO
  TRICYCLE
  CAR
  VAN
}

enum ShopStatus {
  DRAFT
  ACTIVE
  SUSPENDED
}

model Shop {
  id          String     @id @default(cuid())
  owner_id    String
  name        String
  slug        String     @unique
  description String?
  logo        String?
  cover_image String?
  phone       String?
  whatsapp    String?
  email       String?
  country     String     @default("CI")
  city        String     @default("Abidjan")
  district    String?
  address     String?
  merchant_id String?    @unique
  status      ShopStatus @default(DRAFT)
  is_active   Boolean    @default(true)
  marketplace_featured Boolean @default(false)
  enabled_modules      String[] @default(["catalog"])
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt

  owner    User                 @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  merchant Merchant?            @relation(fields: [merchant_id], references: [id], onDelete: SetNull)
  products Product[]
  orders   Order[]
  payments PaymentTransaction[]
  promotions Promotion[]
  delivery_zones ShopDeliveryZone[]
  product_categories ShopProductCategory[]
  collections      ShopCollection[]
  menu_sections    MenuSection[]
  menu_items       MenuItem[]
  order_returns    OrderReturn[]

  @@index([owner_id])
  @@index([slug])
  @@index([merchant_id])
  @@index([status])
  @@index([is_active])
}

enum ProductStatus {
  DRAFT
  ACTIVE
  OUT_OF_STOCK
  ARCHIVED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum DeliveryType {
  PICKUP
  DELIVERY
}

model ShopDeliveryZone {
  id                      String          @id @default(cuid())
  shop_id                 String
  name                    String
  description             String?
  fee                     Int
  min_order_amount        Int?
  free_delivery_threshold Int?
  eta_min_minutes         Int
  eta_max_minutes         Int
  vehicle                 DeliveryVehicle @default(MOTO)
  is_active               Boolean         @default(true)
  priority                Int             @default(0)
  sort_order              Int             @default(0)
  created_at              DateTime        @default(now())
  updated_at              DateTime        @updatedAt

  shop  Shop                   @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  rules ShopDeliveryZoneRule[]

  @@index([shop_id, is_active])
}

model ShopDeliveryZoneRule {
  id           String  @id @default(cuid())
  zone_id      String
  city_id      String
  all_communes Boolean @default(false)

  zone      ShopDeliveryZone          @relation(fields: [zone_id], references: [id], onDelete: Cascade)
  city      GeoCity                   @relation(fields: [city_id], references: [id], onDelete: Cascade)
  communes  ShopDeliveryZoneCommune[]

  @@index([zone_id])
  @@index([city_id])
}

model ShopDeliveryZoneCommune {
  zone_rule_id String
  commune_id   String

  rule    ShopDeliveryZoneRule @relation(fields: [zone_rule_id], references: [id], onDelete: Cascade)
  commune GeoCommune           @relation(fields: [commune_id], references: [id], onDelete: Cascade)

  @@id([zone_rule_id, commune_id])
}

model Product {
  id             String        @id @default(cuid())
  shop_id        String
  category_id    String?
  name           String
  slug           String
  description    String?
  composition    String?
  price          Int
  currency       String        @default("XOF")
  stock_quantity Int           @default(0)
  image_url      String?
  allow_pickup   Boolean       @default(true)
  allow_delivery Boolean       @default(true)
  status         ProductStatus @default(DRAFT)
  sort_order     Int           @default(0)
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt

  shop        Shop             @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  category    ProductCategory? @relation(fields: [category_id], references: [id], onDelete: SetNull)
  variants    ProductVariant[]
  images      ProductImage[]
  cart_items  CartItem[]
  order_items OrderItem[]
  favorites   ProductFavorite[]
  collections ProductCollection[]
  reviews     ProductReview[]
  views       ProductView[]

  @@unique([shop_id, slug])
  @@index([shop_id, status])
  @@index([category_id])
}

model ProductView {
  id         String   @id @default(cuid())
  product_id String
  user_id    String?
  guest_key  String?
  country    String   @default("CI")
  viewed_at  DateTime @default(now())

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, viewed_at])
  @@index([guest_key, viewed_at])
  @@index([product_id])
}

model ProductImage {
  id         String   @id @default(cuid())
  product_id String
  url        String
  sort_order Int      @default(0)
  created_at DateTime @default(now())

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id, sort_order])
}

model ProductVariant {
  id             String   @id @default(cuid())
  product_id     String
  name           String
  price          Int
  stock_quantity Int      @default(0)
  sku            String?
  sort_order     Int      @default(0)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  product     Product     @relation(fields: [product_id], references: [id], onDelete: Cascade)
  cart_items  CartItem[]
  order_items OrderItem[]

  @@index([product_id])
}

model Cart {
  id         String   @id @default(cuid())
  user_id    String   @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user  User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  items CartItem[]

  @@index([user_id])
}

model CartItem {
  id                 String   @id @default(cuid())
  cart_id            String
  product_id         String?
  menu_item_id       String?
  variant_id         String?
  quantity           Int      @default(1)
  selected_modifiers Json     @default("[]")
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  cart      Cart            @relation(fields: [cart_id], references: [id], onDelete: Cascade)
  product   Product?        @relation(fields: [product_id], references: [id], onDelete: Cascade)
  menu_item MenuItem?       @relation(fields: [menu_item_id], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variant_id], references: [id], onDelete: SetNull)

  @@index([cart_id])
  @@index([cart_id, product_id, variant_id])
  @@index([cart_id, menu_item_id])
}

enum OrderSource {
  MARKETPLACE
  FOOD
}

enum OrderReturnStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

model OrderReturn {
  id            String            @id @default(cuid())
  order_id      String            @unique
  user_id       String
  shop_id       String?
  reason        String
  description   String?
  status        OrderReturnStatus @default(PENDING)
  merchant_note String?
  created_at    DateTime          @default(now())
  updated_at    DateTime          @updatedAt
  resolved_at   DateTime?

  order Order @relation(fields: [order_id], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  shop  Shop? @relation(fields: [shop_id], references: [id], onDelete: SetNull)

  @@index([shop_id, status])
  @@index([user_id])
}

model Order {
  id                  String       @id @default(cuid())
  user_id             String
  shop_id             String?
  merchant_id         String?
  order_source        OrderSource  @default(MARKETPLACE)
  promotion_id        String?
  status              OrderStatus  @default(PENDING)
  delivery_type       DeliveryType @default(PICKUP)
  delivery_address    String?
  delivery_city_id    String?
  delivery_commune_id String?
  delivery_district   String?
  customer_note       String?
  customer_phone      String?
  subtotal            Int
  discount_amount     Int          @default(0)
  delivery_fee        Int          @default(0)
  total               Int
  currency            String       @default("XOF")
  created_at          DateTime     @default(now())
  updated_at          DateTime     @updatedAt

  user        User                 @relation(fields: [user_id], references: [id], onDelete: Cascade)
  shop        Shop?                @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  merchant    Merchant?            @relation(fields: [merchant_id], references: [id], onDelete: SetNull)
  promotion   Promotion?           @relation(fields: [promotion_id], references: [id], onDelete: SetNull)
  items       OrderItem[]
  payment     PaymentTransaction?
  redemption  PromotionRedemption?
  delivery_job DeliveryJob?
  return_request OrderReturn?

  @@index([user_id])
  @@index([shop_id, status])
  @@index([merchant_id, status])
  @@index([created_at])
  @@index([promotion_id])
}

model OrderItem {
  id           String  @id @default(cuid())
  order_id     String
  product_id   String?
  menu_item_id String?
  variant_id   String?
  product_name String
  variant_name String?
  unit_price   Int
  quantity     Int
  line_total   Int
  modifiers    Json    @default("[]")

  order     Order           @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product   Product?        @relation(fields: [product_id], references: [id], onDelete: SetNull)
  menu_item MenuItem?       @relation(fields: [menu_item_id], references: [id], onDelete: SetNull)
  variant   ProductVariant? @relation(fields: [variant_id], references: [id], onDelete: SetNull)

  @@index([order_id])
  @@index([menu_item_id])
}

// ─── DELIVERY ENGINE V3.0 ─────────────────────────────────────────────────────

enum DeliveryJobStatus {
  PENDING
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
  CANCELLED
}

model DeliveryCourier {
  id         String          @id @default(cuid())
  full_name  String
  phone      String
  country    String          @default("CI")
  city       String
  vehicle    DeliveryVehicle @default(MOTO)
  is_active  Boolean         @default(true)
  created_at DateTime        @default(now())

  jobs DeliveryJob[]

  @@index([country, city, is_active])
}

model DeliveryJob {
  id              String            @id @default(cuid())
  order_id        String            @unique
  courier_id      String?
  status          DeliveryJobStatus @default(PENDING)
  tracking_token  String            @unique @default(cuid())
  pickup_address  String?
  dropoff_address String?
  assigned_at     DateTime?
  picked_up_at    DateTime?
  delivered_at    DateTime?
  eta_minutes     Int?
  notes           String?
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt

  order   Order            @relation(fields: [order_id], references: [id], onDelete: Cascade)
  courier DeliveryCourier? @relation(fields: [courier_id], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([courier_id])
  @@index([tracking_token])
}

model ShopCollection {
  id          String   @id @default(cuid())
  shop_id     String
  name        String
  slug        String
  description String?
  sort_order  Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  shop     Shop                @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  products ProductCollection[]

  @@unique([shop_id, slug])
  @@index([shop_id, is_active, sort_order])
}

model ProductCollection {
  product_id    String
  collection_id String
  sort_order    Int @default(0)

  product    Product        @relation(fields: [product_id], references: [id], onDelete: Cascade)
  collection ShopCollection @relation(fields: [collection_id], references: [id], onDelete: Cascade)

  @@id([product_id, collection_id])
  @@index([collection_id, sort_order])
}
